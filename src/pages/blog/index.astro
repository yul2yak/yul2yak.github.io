---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = await getCollection('blog');

// 정렬 옵션
const sort = Astro.url.searchParams.get('sort') || 'recent';
let sortedPosts = posts;
if (sort === 'title') {
	sortedPosts = posts.sort((a, b) => a.data.title.localeCompare(b.data.title));
} else if (sort === 'popular') {
	// 임시: 랜덤 정렬 (나중에 조회수로 변경)
	sortedPosts = posts.sort(() => Math.random() - 0.5);
} else {
	sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
}

// 보기 모드
const view = Astro.url.searchParams.get('view') || 'card';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Blog`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
			}
			.controls {
				display: flex;
				justify-content: space-between;
				margin-bottom: 2em;
				flex-wrap: wrap;
				gap: 1em;
			}
			.controls select {
				padding: 0.5em;
				border: 1px solid #ccc;
				border-radius: 4px;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			/* 카드 보기 */
			.view-card ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
			}
			.view-card ul li {
				width: calc(50% - 1rem);
			}
			.view-card ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			.view-card ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			.view-card ul li:first-child img {
				width: 100%;
			}
			.view-card ul li:first-child .title {
				font-size: 2.369rem;
			}
			.view-card ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			.view-card ul li a {
				display: block;
			}
			.view-card .title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.view-card .date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.view-card ul li a:hover h4,
			.view-card ul li a:hover .date {
				color: rgb(var(--accent));
			}
			.view-card ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			/* 리스트 보기 */
			.view-list ul li {
				border-bottom: 1px solid #eee;
				padding: 1em 0;
			}
			.view-list .post-item {
				display: flex;
				gap: 1em;
				align-items: flex-start;
			}
			.view-list .post-image {
				flex-shrink: 0;
				width: 120px;
				height: 80px;
				object-fit: cover;
				border-radius: 8px;
			}
			.view-list .post-content {
				flex: 1;
			}
			.view-list .title {
				margin: 0 0 0.5em 0;
				font-size: 1.25em;
			}
			.view-list .date {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin-bottom: 0.5em;
			}
			.view-list .description {
				color: rgb(var(--gray-dark));
				line-height: 1.5;
			}
			@media (max-width: 720px) {
				.view-card ul {
					gap: 0.5em;
				}
				.view-card ul li {
					width: 100%;
					text-align: center;
				}
				.view-card ul li:first-child {
					margin-bottom: 0;
				}
				.view-card ul li:first-child .title {
					font-size: 1.563em;
				}
				.view-list .post-item {
					flex-direction: column;
				}
				.view-list .post-image {
					width: 100%;
					height: 200px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="controls">
					<div>
						<label for="sort">정렬: </label>
						<select id="sort" onchange="changeSort(this.value)">
							<option value="recent" {sort === 'recent' ? 'selected' : ''}>최신순</option>
							<option value="title" {sort === 'title' ? 'selected' : ''}>제목순</option>
							<option value="popular" {sort === 'popular' ? 'selected' : ''}>인기순</option>
						</select>
					</div>
					<div>
						<label for="view">보기: </label>
						<select id="view" onchange="changeView(this.value)">
							<option value="card" {view === 'card' ? 'selected' : ''}>카드</option>
							<option value="list" {view === 'list' ? 'selected' : ''}>리스트</option>
						</select>
					</div>
				</div>
				<div class={`view-${view}`}>
					<ul>
						{
							sortedPosts.map((post) => (
								view === 'card' ? (
									<li>
										<a href={`/blog/${post.id}/`}>
											{post.data.heroImage && (
												<Image width={720} height={360} src={post.data.heroImage} alt="" />
											)}
											<h4 class="title">{post.data.title}</h4>
											<p class="date">
												<FormattedDate date={post.data.pubDate} />
											</p>
										</a>
									</li>
								) : (
									<li>
										<div class="post-item">
											{post.data.heroImage && (
												<Image class="post-image" width={120} height={80} src={post.data.heroImage} alt="" />
											)}
											<div class="post-content">
												<h4 class="title"><a href={`/blog/${post.id}/`}>{post.data.title}</a></h4>
												<p class="date">
													<FormattedDate date={post.data.pubDate} />
												</p>
												<p class="description">{post.data.description}</p>
											</div>
										</div>
									</li>
								)
							))
						}
					</ul>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			function changeSort(value) {
				const url = new URL(window.location);
				url.searchParams.set('sort', value);
				window.location.href = url.toString();
			}
			function changeView(value) {
				const url = new URL(window.location);
				url.searchParams.set('view', value);
				window.location.href = url.toString();
			}
		</script>
	</body>
</html>
